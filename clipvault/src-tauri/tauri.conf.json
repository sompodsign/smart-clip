{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SmartClip",
  "version": "0.4.2",
  "identifier": "com.smartclip.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SmartClip",
        "width": 340,
        "height": 400,
        "visible": false,
        "resizable": true,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "focus": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "connect-src": "ipc: http://ipc.localhost https://github.com https://objects.githubusercontent.com",
        "font-src": "'self' https://fonts.gstatic.com",
        "style-src": "'unsafe-inline' 'self' https://fonts.googleapis.com"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$APPDATA/images/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "",
      "exceptionDomain": "",
      "signingIdentity": null,
      "entitlements": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzN0E0ODVBMjdGMUUwNApSV1FFSG4raWhhUTNCZXZlM3NsWXkwYS92cTZSK0F0Wmk2Q3ZWWjhDYjBjdXh2eEJHOGVOUG1xRwo=",
      "endpoints": [
        "https://storage.googleapis.com/capaccino/latest.json"
      ]
    }
  }
}
